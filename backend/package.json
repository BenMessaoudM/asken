{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "node --env-file=.env -r ts-node/register src/index.ts",
    "test": "jest --runInBand",
    "migrate": "node --env-file=.env -r ts-node/register src/database/migrate.ts",
    "seed": "node --env-file=.env -r ts-node/register src/database/seed.ts",
    "smtp:dev": "node --env-file=.env -r ts-node/register src/dev/smtp.ts"
  },
  "dependencies": {
    "@types/pdfkit": "^0.17.6",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.18.1",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.19.1",
    "zod": "^3.20.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.1",
    "@types/smtp-server": "^3.5.13",
    "@types/supertest": "^6.0.0",
    "jest": "^29.7.0",
    "smtp-server": "^3.19.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
