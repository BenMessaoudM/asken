NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017/asken

# Generate independent values with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_64_hex_characters
JWT_REFRESH_SECRET=replace_with_64_hex_characters
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=7
BCRYPT_ROUNDS=12
COOKIE_SECURE=false

FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Local SMTP sink started by npm run smtp:dev
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_AUTH=false
SMTP_SECURE=false
SMTP_USER=dev@asken.local
SMTP_PASS=development-only

# Cor House contract generation. Door code is injected only into generated PDFs.
COR_HOUSE_DOOR_CODE=replace_with_current_door_code
COR_HOUSE_LANDLORD_ADDRESS=Cor House, Arcada campus, Helsinki, Finland
COR_HOUSE_LANDLORD_EMAIL=info@asken.fi
# Comma-separated current board-member emails eligible for the mandate-year private benefit.
COR_HOUSE_BOARD_MEMBER_EMAILS=

SUPER_ADMIN_EMAIL=admin@asken.fi
SUPER_ADMIN_PASSWORD=replace_with_a_strong_temporary_password
SUPER_ADMIN_NAME=Super Admin
