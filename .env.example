NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://localhost:27017/asken

# Authentication: use independent random values of at least 32 characters.
JWT_ACCESS_SECRET=replace_with_a_random_access_secret_32_chars
JWT_REFRESH_SECRET=replace_with_a_random_refresh_secret_32_chars
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=7
BCRYPT_ROUNDS=12
COOKIE_SECURE=false

FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
FRONTEND_PORT=5173
ADMIN_PORT=5174
VITE_API_URL=http://localhost:3000/api/v1
VITE_SITE_URL=http://localhost:5173

SMTP_HOST=replace_me
SMTP_PORT=587
SMTP_USER=replace_me
SMTP_PASS=replace_me

# Required by npm run seed. Password must meet the documented policy.
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ReplaceWithStrongPassword1!
SUPER_ADMIN_NAME=Super Admin

CONTACT_GENERAL=info@asken.fi
CONTACT_ANTIHARASSMENT=hello@asken.fi
HSL_STOPS=[{"id":"HSL:12345","label":"Arabia / Arcada","max":6}]
